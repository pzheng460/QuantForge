//@version=5
strategy("MACD Trend", overlay=true, initial_capital=100000)

// --- Inputs ---
fast_len = input.int(12, title="MACD Fast", minval=8, maxval=20, step=2)
slow_len = input.int(26, title="MACD Slow", minval=20, maxval=40, step=2)
sig_len = input.int(9, title="Signal Length", minval=5, maxval=15, step=2)
adx_len = input.int(14, title="ADX Length")
adx_thresh = input.int(20, title="ADX Threshold", minval=15, maxval=30, step=5)

// --- Indicators ---
fast_ma = ta.ema(close, fast_len)
slow_ma = ta.ema(close, slow_len)
macd_line = fast_ma - slow_ma
signal_line = ta.ema(macd_line, sig_len)
adx_val = ta.adx(adx_len)
trending = adx_val > adx_thresh

// --- Entry: MACD cross + regime filter ---
if trending
    if ta.crossover(macd_line, signal_line)
        strategy.entry("Long", strategy.long)
    if ta.crossunder(macd_line, signal_line)
        strategy.entry("Short", strategy.short)

// --- Flatten in ranging market ---
if not trending
    strategy.close("Long")
    strategy.close("Short")
