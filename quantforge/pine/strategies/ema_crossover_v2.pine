//@version=5
strategy("EMA Crossover v2", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=78)

// --- Inputs ---
fast_period = input.int(5, title="Fast EMA", minval=3, maxval=20, step=1)
slow_period = input.int(13, title="Slow EMA", minval=10, maxval=50, step=1)

// --- Indicators ---
fast = ta.ema(close, fast_period)
slow = ta.ema(close, slow_period)

// --- Entry ---
if ta.crossover(fast, slow)
    strategy.entry("Long", strategy.long)
if ta.crossunder(fast, slow)
    strategy.entry("Short", strategy.short)
