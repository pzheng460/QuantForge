//@version=5
strategy("EMA Crossover v3", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=75)

// --- Inputs ---
fast_period = input.int(6, title="Fast EMA", minval=3, maxval=20, step=1)
slow_period = input.int(13, title="Slow EMA", minval=10, maxval=50, step=1)
adx_period = input.int(14, title="ADX Period")
adx_threshold = input.int(26, title="ADX Threshold", minval=10, maxval=40)
atr_period = input.int(14, title="ATR Period")
stop_loss_mult = input.float(1.5, title="Stop Loss ATR Multiplier", minval=0.5, maxval=3.0, step=0.1)

// --- Indicators ---
fast = ta.ema(close, fast_period)
slow = ta.ema(close, slow_period)
[di_plus, di_minus, adx_val] = ta.dmi(adx_period, adx_period)
atr_val = ta.atr(atr_period)
trending = adx_val > adx_threshold

// --- Entry & Regime Management ---
long_condition = ta.crossover(fast, slow) and trending
short_condition = ta.crossunder(fast, slow) and trending

if long_condition
    strategy.entry("Long", strategy.long)
if short_condition
    strategy.entry("Short", strategy.short)

// --- ATR Stop Losses ---
if strategy.position_size > 0
    strategy.exit("Long_SL", "Long", stop=strategy.position_avg_price - atr_val * stop_loss_mult)
if strategy.position_size < 0
    strategy.exit("Short_SL", "Short", stop=strategy.position_avg_price + atr_val * stop_loss_mult)

// --- Close positions when regime changes to ranging ---
if not trending
    strategy.close("Long")
    strategy.close("Short")
