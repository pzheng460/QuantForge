//@version=5
strategy("EMA Crossover v3", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=78)

// --- Inputs ---
fast_period = input.int(5, title="Fast EMA", minval=3, maxval=20, step=1)
slow_period = input.int(13, title="Slow EMA", minval=10, maxval=50, step=1)
adx_period = input.int(14, title="ADX Period")
adx_threshold = input.int(20, title="ADX Threshold", minval=10, maxval=40)

// --- Indicators ---
fast = ta.ema(close, fast_period)
slow = ta.ema(close, slow_period)
[di_plus, di_minus, adx_val] = ta.dmi(adx_period, adx_period)
trending = adx_val > adx_threshold

// --- Entry (ADX entry-only filter, NO regime close) ---
if ta.crossover(fast, slow) and trending
    strategy.entry("Long", strategy.long)
if ta.crossunder(fast, slow) and trending
    strategy.entry("Short", strategy.short)
