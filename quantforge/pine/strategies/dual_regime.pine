//@version=5
strategy("Dual Regime Adaptive", overlay=true, initial_capital=100000)

// --- Inputs ---
adx_period = input.int(14, title="ADX Period", minval=7, maxval=21, step=7)
adx_threshold = input.int(25, title="ADX Threshold", minval=15, maxval=35, step=5)
ema_fast = input.int(8, title="EMA Fast", minval=3, maxval=20, step=2)
ema_slow = input.int(21, title="EMA Slow", minval=10, maxval=50, step=5)
ema_trend = input.int(100, title="EMA Trend", minval=50, maxval=200, step=25)
roc_period = input.int(10, title="ROC Period", minval=5, maxval=30, step=5)
bb_period = input.int(20, title="BB Period", minval=10, maxval=50, step=5)
bb_multiplier = input.float(2.0, title="BB Multiplier", minval=1.0, maxval=3.0, step=0.5)
atr_period = input.int(14, title="ATR Period", minval=7, maxval=21, step=7)
stop_loss_pct = input.float(0.03, title="Stop Loss %", minval=0.01, maxval=0.10, step=0.01)

// --- Indicators ---
adx_val = ta.adx(high, low, close, adx_period)
fast = ta.ema(close, ema_fast)
slow = ta.ema(close, ema_slow)
trend = ta.ema(close, ema_trend)
roc_val = ta.roc(close, roc_period)
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_period, bb_multiplier)
atr_val = ta.atr(atr_period)

// --- Regime detection ---
is_trending = adx_val >= adx_threshold

// --- Trending regime: momentum strategy ---
trend_long = is_trending and roc_val > 0 and fast > slow and close > trend
trend_short = is_trending and roc_val < 0 and fast < slow and close < trend

// --- Ranging regime: mean reversion strategy ---
range_long = not is_trending and close <= bb_lower
range_short = not is_trending and close >= bb_upper

// --- Combined entries ---
if trend_long or range_long
    strategy.entry("Long", strategy.long)
if trend_short or range_short
    strategy.entry("Short", strategy.short)

// --- Exits ---
// Trending: EMA crossover exit
if is_trending and strategy.position_size > 0 and fast < slow
    strategy.close("Long")
if is_trending and strategy.position_size < 0 and fast > slow
    strategy.close("Short")

// Ranging: middle band exit
if not is_trending and strategy.position_size > 0 and close >= bb_mid
    strategy.close("Long")
if not is_trending and strategy.position_size < 0 and close <= bb_mid
    strategy.close("Short")
