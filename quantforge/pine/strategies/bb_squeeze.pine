//@version=5
strategy("BB Squeeze Breakout", overlay=true, initial_capital=100000)

// --- Inputs ---
bb_len = input.int(20, title="BB Length", minval=10, maxval=40, step=5)
bb_std = input.float(2.0, title="BB StdDev", minval=1.5, maxval=3.0, step=0.5)
ema_fast = input.int(8, title="Fast EMA", minval=5, maxval=15, step=1)
ema_slow = input.int(21, title="Slow EMA", minval=15, maxval=30, step=1)

// --- Indicators ---
basis = ta.sma(close, bb_len)
dev = bb_std * ta.stdev(close, bb_len)
upper = basis + dev
lower = basis - dev
bb_width = (upper - lower) / basis
fast = ta.ema(close, ema_fast)
slow = ta.ema(close, ema_slow)

// --- Squeeze detection: BB width contracting ---
avg_width = ta.sma(bb_width, bb_len)
squeeze = bb_width < avg_width

// --- Breakout from squeeze ---
if squeeze[1] and not squeeze
    if fast > slow
        strategy.entry("Long", strategy.long)
    if fast < slow
        strategy.entry("Short", strategy.short)

// --- Exit on opposite band touch ---
if close > upper
    strategy.close("Long")
if close < lower
    strategy.close("Short")
