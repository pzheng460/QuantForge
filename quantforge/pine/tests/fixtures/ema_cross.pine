//@version=5
strategy("EMA Crossover", overlay=true, initial_capital=10000, commission_value=0.1)

fast_len = input.int(9, title="Fast Length")
slow_len = input.int(21, title="Slow Length")

fast_ema = ta.ema(close, fast_len)
slow_ema = ta.ema(close, slow_len)

long_condition = ta.crossover(fast_ema, slow_ema)
short_condition = ta.crossunder(fast_ema, slow_ema)

if long_condition
    strategy.entry("Long", strategy.long)

if short_condition
    strategy.close("Long")
